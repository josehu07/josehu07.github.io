// Place your key bindings in this file to override the defaults
[
    {
        "key": "shift+alt+c",
        "command": "commentBox.addUsingStyle",
        "when": "editorTextFocus"
    },
    {
        "key": "shift+alt+x",
        "command": "commentBox.removeUsingStyle",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+cmd+q",
        "command": "-aws.amazonq.sendToPrompt",
        "when": "aws.codewhisperer.connected"
    },
    {
        "key": "shift+cmd+e",
        "command": "rust-analyzer.openExternalDocs"
    },
    {
        "key": "shift+cmd+d",
        "command": "editor.action.revealDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus"
    },
    {
        "key": "f12",
        "command": "-editor.action.revealDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus"
    },
    {
        "key": "shift+cmd+r",
        "command": "editor.action.goToReferences",
        "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "shift+f12",
        "command": "-editor.action.goToReferences",
        "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "shift+cmd+/",
        "command": "workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "shift+cmd+e",
        "command": "-workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "shift+alt+cmd+/",
        "command": "workbench.view.remote"
    },
    {
        "key": "shift+cmd+9",
        "command": "workbench.view.debug",
        "when": "viewContainer.workbench.view.debug.enabled"
    },
    {
        "key": "shift+cmd+d",
        "command": "-workbench.view.debug",
        "when": "viewContainer.workbench.view.debug.enabled"
    },
    {
        "key": "shift+cmd+0",
        "command": "workbench.view.scm",
        "when": "workbench.scm.active"
    },
    {
        "key": "ctrl+shift+g",
        "command": "-workbench.view.scm",
        "when": "workbench.scm.active"
    },
    {
        "key": "shift+cmd+0",
        "command": "workbench.view.scm",
        "when": "workbench.scm.active && !gitlens:disabled && config.gitlens.keymap == 'chorded'"
    },
    {
        "key": "ctrl+shift+g",
        "command": "-workbench.view.scm",
        "when": "workbench.scm.active && !gitlens:disabled && config.gitlens.keymap == 'chorded'"
    },
        {
        "key": "alt+cmd+b",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    {
        "key": "cmd+b",
        "command": "-workbench.action.toggleSidebarVisibility"
    },
    {
        "key": "cmd+b",
        "command": "workbench.action.toggleAuxiliaryBar"
    },
    {
        "key": "alt+cmd+b",
        "command": "-workbench.action.toggleAuxiliaryBar"
    },
    {
        "key": "shift+cmd+8",
        "command": "gitlens.toggleFileBlame"
    },
    {
        "key": "cmd+escape",
        "command": "claude-vscode.editor.open"
    },
    {
        "key": "shift+cmd+escape",
        "command": "claude-vscode.sidebar.open"
    },
    {
        "key": "shift+cmd+escape",
        "command": "-claude-vscode.editor.open",
        "when": "!config.claudeCode.useTerminal"
    },
    {
        "key": "shift+cmd+1",
        "command": "chatgpt.openSidebar"
    },
    {
        "key": "ctrl+l ctrl+b",
        "command": "latex-workshop.surround",
        "args": "textbf",
        "when": "editorTextFocus && editorLangId == 'latex'"
    },
    {
        "key": "ctrl+l ctrl+i",
        "command": "latex-workshop.surround",
        "args": "textit",
        "when": "editorTextFocus && editorLangId == 'latex'"
    }
]
